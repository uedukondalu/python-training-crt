a=input("enter password :")
sp=0
up=0
lo=0
dg=0
if len(a)>7:
    for i in a:
        if i.isupper():
            up+=1
        elif i.islower():
            lo+=1
        elif i.isdigit():
            dg+=1
        else:
            sp+=1
    if up>0 and sp>0 and dg>0 and lo>0:
        print("strong")
    else:
        print("weak")
else:
    ("weak due to less char")
